ZOTERO_LIBRARY_ID=
ZOTERO_LIBRARY_TYPE=user
ZOTERO_API_KEY=
CROSSREF_MAILTO=your-email@example.com
CROSSREF_SCORE_THRESHOLD=30
INPUT_BIB=reference.bib
COLLECTION_PREFIX=Paper_Refs
REQUEST_DELAY_SECONDS=0.3
# Query 检索 Tab：每条子检索串从 Crossref 取回的条数
CROSSREF_QUERY_TOP_K=10
# Query 规则打分标签阈值（0~1）
QUERY_SCORE_RECOMMENDED=0.72
QUERY_SCORE_CONSIDER=0.45
ZOTERO_AUTO_IMPORT=true
ZOTERO_SKIP_EXISTING_DOI=true

PIPELINE_MODE=verification
CLAIM_TEXT=
SEGMENT_ID=segment_001
CLAIMS_INPUT_PATH=claims.txt
SEMANTIC_SCHOLAR_API_KEY=
SEMANTIC_SCHOLAR_BASE_URL=https://api.semanticscholar.org/graph/v1
SEMANTIC_SCHOLAR_TIMEOUT_SECONDS=20
SEMANTIC_SCHOLAR_TOP_K=5
REVIEW_LOG_PATH=review_logs/full_pipeline_reviews.jsonl
REVIEW_FEEDBACK_PATH=review_logs/full_pipeline_feedback.jsonl
SELECTED_RANK=
SELECTED_DOI=
SELECTED_TITLE=
REVIEW_ACTION=
REVIEW_NOTES=
